/init:
  test: ./init.sh
  duration: 1h
  order: 50
  environment:
    TEST_CASE: init

# Runs `cosa build` to produce the OSTree commit and base image artifacts.
/build-fcos:
  test: ./build.sh
  duration: 1h
  order: 60
  environment:
    TEST_CASE: build-fcos

# Runs `cosa osbuild qemu` to produce the qcow2 disk image used by kola QEMU tests.
/build-qemu:
  test: ./build.sh
  duration: 1h
  order: 70
  environment:
    TEST_CASE: build-qemu

# Boots the qcow2 image in QEMU VMs and runs the full kola integration test suite.
/test-qemu:
  test: ./test.sh
  duration: 2h
  order: 80
  environment:
    TEST_CASE: test-qemu

# Verifies that a system on the previous release can upgrade to the newly built image.
/test-kola-upgrade:
  test: ./test.sh
  duration: 1h
  order: 90
  environment:
    TEST_CASE: test-kola-upgrade
